# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and adjust the values for THIS machine.
# (On first run `npm run setup` creates the .env for you automatically.)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Use the password you set when installing PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cisterni

# ── Web server ───────────────────────────────────────────────────────────────
# The whole app (UI + API) is served on this port: http://localhost:4000
PORT=4000

# ── MODBUS / PLC serial connection ───────────────────────────────────────────
# IMPORTANT: set the serial port for THIS machine.
#   Windows: COM3   (check Device Manager → Ports)
#   Linux:   /dev/ttyUSB0
#   macOS:   /dev/cu.wchusbserial14140
MODBUS_PORT=COM3
MODBUS_ID=1
MODBUS_BAUD=115200
MODBUS_PARITY=none
MODBUS_DATA_BITS=8
MODBUS_STOP_BITS=1
MODBUS_TIMEOUT=3000
MODBUS_MASS_TYPE=FLOAT32

MODBUS_ADDRESS_OFFSET=4096
MODBUS_32BIT_WORD_ORDER=LOW_HIGH
MODBUS_MASS_SCALE=1
MODBUS_TEMPERATURE_SCALE=1

# ── PLC register map (D-registers, without the Modbus offset) ─────────────────
REG_MASS_BASE=800
REG_TEMPS_BASE=832
REG_ALARM_LOW=848
REG_ALARM_HIGH=849
REG_OVERHEAT=850

# How often to read the PLC (milliseconds)
COLLECT_INTERVAL_MS=60000
