@echo off
REM ─────────────────────────────────────────────────────────────────────────
REM  Стартира приложението (backend + готовия frontend) и отваря таблото.
REM  Двоен клик върху този файл = пуска сървъра и отваря http://localhost:4000
REM ─────────────────────────────────────────────────────────────────────────

REM Влиза в папката на този .bat файл (работи независимо откъде е стартиран).
cd /d "%~dp0"

REM Пуска сървъра в отделен прозорец (остава отворен, за да виждаш логовете).
start "Cisterni" cmd /k "npm start"

REM Изчаква сървърът да се вдигне (билд на frontend + старт), после отваря браузъра.
echo Стартиране на сървъра... отваряне на таблото след малко.
timeout /t 8 /nobreak >nul

start "" "http://localhost:4000"
